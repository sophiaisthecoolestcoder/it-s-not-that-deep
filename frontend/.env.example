# Backend API base URL — required for production web builds.
#
# webpack.config.js inlines this via DefinePlugin at build time. If unset
# during a prod build, the bundle silently falls back to http://localhost:8000/api,
# which will not work outside a developer's machine.
#
# Native dev (Metro) reads it at runtime from process.env; the platform-specific
# fallback in src/api/client.ts (Android emulator → 10.0.2.2) only kicks in if
# nothing is set.
REACT_APP_API_URL=http://localhost:8000/api

# Optional: override the dev-server port (default 3333).
PORT=3333
