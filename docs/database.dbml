// Bleiche Resort & Spa — Database Schema (DBML)
// This file must always reflect the current database structure.
// Update it whenever migrations change the schema.

Project bleiche_hotel {
  database_type: 'PostgreSQL'
  Note: 'Hotel management system for Bleiche Resort & Spa, Spreewald'
}

Enum employeerole {
  manager
  receptionist
  housekeeper
  spa_therapist
  chef
  waiter
  concierge
  maintenance
  admin
}

Enum salutation {
  Herr
  Frau
  Familie
}

Enum offerstatus {
  draft
  sent
  accepted
  declined
}

Table employees {
    id         integer      [pk, increment]
    first_name varchar(100) [not null]
    last_name  varchar(100) [not null]
    email      varchar(255) [not null, unique, note: 'indexed']
    phone      varchar(30)
    role       employeerole [not null]
    created_at timestamptz  [default: `now()`]
    updated_at timestamptz  [default: `now()`]
}

Table users {
    id                        integer      [pk, increment]
    username                  varchar(100) [not null, unique, note: 'indexed']
    password_hash             varchar(255) [not null]
    role                      employeerole [not null]
    employee_id               integer
    is_active                 boolean      [not null, default: true]
    must_change_password      boolean      [not null, default: false]
    tokens_invalidated_before timestamptz
    created_at                timestamptz  [default: `now()`]
    updated_at                timestamptz  [default: `now()`]
}

Table guests {
    id            integer      [pk, increment]
    first_name    varchar(100) [not null]
    last_name     varchar(100) [not null]
    email         varchar(255) [not null, unique, note: 'indexed']
    phone         varchar(30)
    date_of_birth date
    address       text
    nationality   varchar(100)
    notes         text
    created_at    timestamptz  [default: `now()`]
    updated_at    timestamptz  [default: `now()`]
}

Table offers {
    id                   integer      [pk, increment]
    salutation           salutation   [not null]
    first_name           varchar(100) [not null, default: '']
    last_name            varchar(100) [not null, default: '']
    street               varchar(255) [not null, default: '']
    zip_code             varchar(20)  [not null, default: '']
    city                 varchar(100) [not null, default: '']
    email                varchar(255) [not null, default: '']
    offer_date           date
    arrival_date         date
    departure_date       date
    room_category        varchar(100) [not null, default: '']
    custom_room_category varchar(255) [not null, default: '']
    adults               integer      [not null, default: 2]
    children_ages        integer[]    [not null, default: `'{}'`]
    price_per_night      varchar(50)  [not null, default: '']
    total_price          varchar(50)  [not null, default: '']
    employee_name        varchar(200) [not null, default: '']
    notes                text         [not null, default: '']
    status               offerstatus  [not null, default: 'draft']
    created_at           timestamptz  [default: `now()`]
    updated_at           timestamptz  [default: `now()`]
}

Table daily_briefings {
    id         integer     [pk, increment]
    date       date        [not null, unique]
    data       jsonb       [not null]
    created_at timestamptz [default: `now()`]
    updated_at timestamptz [default: `now()`]
}

Table staff_members {
    id         integer      [pk, increment]
    name       varchar(200) [not null, unique]
    created_at timestamptz  [default: `now()`]
}

Table rooms {
    number   varchar(10) [pk]
    category varchar(20) [not null]
    floor    varchar(20) [not null]
}

Table conversations {
    id             integer     [pk, increment]
    user_id        integer     [not null, note: 'indexed']
    title          varchar(200) [not null, default: '']
    created_at     timestamptz [not null, default: `now()`]
    last_active_at timestamptz [not null, default: `now()`]
}

Table conversation_messages {
    id                 integer     [pk, increment]
    conversation_id    integer     [not null, note: 'indexed']
    role               varchar(16) [not null, note: 'user | assistant | tool']
    content            text        [not null, default: '']
    tool_call_id       varchar(80)
    tool_name          varchar(80)
    tool_calls         jsonb
    refs               jsonb
    prompt_tokens      integer     [not null, default: 0]
    completion_tokens  integer     [not null, default: 0]
    cost_micro_cents   integer     [not null, default: 0]
    model              varchar(80)
    created_at         timestamptz [not null, default: `now()`]

    indexes {
        (conversation_id, created_at) [name: 'ix_conv_msg_conv_created']
    }
}

Ref: users.employee_id > employees.id
Ref: conversations.user_id > users.id [delete: cascade]
Ref: conversation_messages.conversation_id > conversations.id [delete: cascade]

