# Secrets — any .env file anywhere
.env
.env.*
!.env.example
!backend/.env.example
!frontend/.env.example

# Python
backend/venv/
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.mypy_cache/

# Node
frontend/node_modules/
frontend/.metro-health-check*
frontend/dist/
frontend/web-build/

# Generated by frontend/scripts/copy-pdf-worker.js (postinstall hook).
# Reproducible from node_modules/pdfjs-dist; no need to track.
frontend/web/pdf.worker.min.mjs
frontend/web/pdfjs-standard-fonts/
frontend/web/pdfjs-cmaps/

# Local-only floor-plan inspector tool. Run with:
#   python -m scripts.floorplan_inspector
# It edits docs/_reference/floorplans/floorplan_overrides.json (which IS
# tracked — that's the canonical theme config the team shares). The
# inspector itself is dev-only and not part of the shipped product.
backend/scripts/floorplan_inspector.py

# iOS
frontend/ios/Pods/
frontend/ios/build/

# Android
frontend/android/.gradle/
frontend/android/app/build/
frontend/android/build/
*.apk
*.aab

# IDE
.idea/
.vscode/
*.swp
*.swo
.DS_Store
