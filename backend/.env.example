# Database connection (required)
DATABASE_URL=postgresql://username:password@host:5432/database_name

# Runtime secrets (required, min 32 chars)
JWT_SECRET=replace-with-a-long-random-secret

# Access token lifetime (seconds). Default: 8 hours.
TOKEN_TTL_SECONDS=28800

# CORS — comma-separated list of allowed origins. Set to your real frontend URL in production.
ALLOWED_ORIGINS=http://localhost:3333,http://localhost:3000,http://localhost:8080,http://localhost:19006

# Max request body size in bytes (1 MiB default).
MAX_BODY_BYTES=1048576

# Logging
LOG_LEVEL=INFO

# Optional: Groq API for LLM features
GROQ_API_KEY=replace-with-your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile
# Price per 1M tokens, USD. Update when Groq changes pricing.
GROQ_INPUT_PRICE_PER_MTOK=0.59
GROQ_OUTPUT_PRICE_PER_MTOK=0.79

# ── Fiscalization / POS (fiskaly KassenSichV DE) ────────────────────────────
# Leave blank and the cashier falls back to a deterministic MOCK signer so the
# UI still works end-to-end without fiskaly creds. Paste real values here once
# you've set up a DEMO environment at https://dashboard.fiskaly.com/.
FISKALY_API_KEY=
FISKALY_API_SECRET=
FISKALY_TSS_ID=
FISKALY_CLIENT_ID=
FISKALY_API_BASE_URL=https://kassensichv-middleware.fiskaly.com
# Optional: force a provider. Values: fiskaly | mock. Blank = auto (fiskaly if
# all the above are set, else mock).
FISCAL_PROVIDER=
