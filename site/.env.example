# Canonical URL the site will be deployed under. Used by Astro's sitemap +
# <link rel="canonical"> tags. Override in production to e.g. https://www.bleiche-resort.de.
PUBLIC_SITE_URL=http://localhost:4321

# Backend API base URL consumed by the public data islands (events widget, etc.).
# For local dev against a local backend: http://localhost:8000
# For production: https://api.bleiche-resort.de
PUBLIC_API_BASE_URL=http://localhost:8000
