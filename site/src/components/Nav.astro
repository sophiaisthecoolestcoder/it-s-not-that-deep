---
/**
 * Top navigation rail — slim, icon-first, hamburger for the full menu.
 * Goes transparent when `overlay=true` (over hero video) and gets a subtle
 * cream pane when scrolled.
 *
 * The hamburger opens a full-screen menu implemented in the React island.
 */
import HamburgerMenu from "@/components/islands/HamburgerMenu.tsx";

interface Props {
  overlay?: boolean;
}
const { overlay = false } = Astro.props;
---

<header
  id="site-nav"
  class:list={[
    "fixed top-0 left-0 right-0 z-40 transition-colors duration-500 out-slow",
    overlay ? "bg-transparent" : "bg-sand-50/90 backdrop-blur",
  ]}
  data-overlay={overlay}
>
  <div class="max-w-screen-2xl mx-auto px-6 md:px-10 py-5 flex items-center justify-between">
    <a
      href="/"
      class:list={[
        "font-display tracking-widest text-sm md:text-base uppercase",
        overlay ? "text-white" : "text-ink-500",
      ]}
    >
      Bleiche Resort <span class="opacity-60">&nbsp;·&nbsp; Spa</span>
    </a>

    <div class="flex items-center gap-5">
      {/* Slim language switch */}
      <div
        class:list={[
          "font-sans text-[11px] tracking-widest uppercase",
          overlay ? "text-white/80" : "text-ink-400",
        ]}
      >
        <a href="/" class="hover:text-sand-400">DE</a>
        <span class="mx-1">|</span>
        <a href="/en" class="hover:text-sand-400">EN</a>
      </div>

      <HamburgerMenu client:load overlay={overlay} />
    </div>
  </div>
</header>

<script>
  // Once the user scrolls past the hero, paint the nav. This runs per-page
  // because Astro's View Transitions rebind `DOMContentLoaded` fires.
  const bind = () => {
    const nav = document.getElementById("site-nav");
    if (!nav) return;
    const isOverlay = nav.dataset.overlay === "true";
    if (!isOverlay) return;
    const onScroll = () => {
      const scrolled = window.scrollY > 80;
      nav.classList.toggle("bg-sand-50/90", scrolled);
      nav.classList.toggle("backdrop-blur", scrolled);
      nav.classList.toggle("bg-transparent", !scrolled);
    };
    onScroll();
    window.addEventListener("scroll", onScroll, { passive: true });
  };
  document.addEventListener("astro:page-load", bind);
</script>
