---
/**
 * Landing page — bleiche.de-style cadence:
 *   1) Full-bleed shaded video hero
 *   2) 3-up chapter tiles  (Rooms, Spa, Arrangements)
 *   3) Chess-block feature (Story / Philosophy)
 *   4) 3-up chapter tiles  (Events, Gallery, Mediathek)
 *   5) Upcoming events (fetched live from /api/public/events)
 *   6) Chess-block feature (Restaurant / Culinary)
 *
 * Content is placeholder — swap images and copy when real material lands in
 * /public/assets/images/.
 */
import BaseLayout from "@/layouts/BaseLayout.astro";
import HeroVideo from "@/components/HeroVideo.astro";
import Tile from "@/components/Tile.astro";
import ChessBlock from "@/components/ChessBlock.astro";
import SmoothScroll from "@/components/islands/SmoothScroll.tsx";
import EventsWidget from "@/components/islands/EventsWidget.tsx";
---

<BaseLayout
  title="Bleiche Resort & Spa — Spreewald"
  description="Ein Refugium aus Stille, Wasser und Wald im Spreewald. Verabreden, ankommen. Sein."
  heroOverlay
>
  <SmoothScroll client:idle />

  <HeroVideo
    videoSrc="/assets/videos/background.mp4"
    poster="/assets/images/hero-poster.jpg"
    tagline="Verabreden, ankommen. Sein."
    subtitle="Bleiche Resort · Spreewald"
  />

  {/* CHAPTER 1 — three pillars */}
  <section id="chapter-1" class="section-bottom-gradient bg-sand-50 pt-28">
    <div class="max-w-screen-xl mx-auto px-6 md:px-10 text-center mb-16">
      <div class="eyebrow mb-4">Drei Welten · Ein Ort</div>
      <h2 class="h-display max-w-3xl mx-auto">
        Ein Ankommen, das an den Rand der Zeit führt.
      </h2>
    </div>
    <div class="grid md:grid-cols-3 gap-[1px] bg-sand-200">
      <Tile
        href="/rooms"
        eyebrow="Wohnen"
        title="Zimmer &amp; Suiten"
        image="/assets/images/placeholder-room.jpg"
      />
      <Tile
        href="/spa"
        eyebrow="Ruhen"
        title="Landtherme Spa"
        image="/assets/images/placeholder-spa.jpg"
      />
      <Tile
        href="/arrangements"
        eyebrow="Erleben"
        title="Arrangements"
        image="/assets/images/placeholder-arrangements.jpg"
      />
    </div>
  </section>

  {/* CHAPTER 2 — chess-block story */}
  <section class="bg-sand-100">
    <ChessBlock
      eyebrow="Unsere Geschichte"
      title="Wo Wasser die Zeit trägt."
      body="Im Herzen des Spreewalds, umspielt von stillen Fließen und alten Erlen, schuf eine Familie einen Ort, der nichts behaupten, sondern atmen will. Seit Generationen wird er gehegt — mit Respekt vor dem Land, dem Handwerk und den Menschen, die hier Gast sind."
      image="/assets/images/placeholder-story.jpg"
      href="/story"
      ctaLabel="Die Geschichte"
      imagePosition="left"
    />
  </section>

  {/* CHAPTER 3 — three invitations */}
  <section class="section-bottom-gradient bg-sand-50 pt-28">
    <div class="max-w-screen-xl mx-auto px-6 md:px-10 text-center mb-16">
      <div class="eyebrow mb-4">Entdecken</div>
      <h2 class="h-display max-w-3xl mx-auto">Kleine Anlässe, lange Pausen.</h2>
    </div>
    <div class="grid md:grid-cols-3 gap-[1px] bg-sand-200">
      <Tile
        href="/events"
        eyebrow="Veranstaltungen"
        title="Was bald geschieht"
        image="/assets/images/placeholder-events.jpg"
      />
      <Tile
        href="/gallery"
        eyebrow="Galerie"
        title="Bilder, die bleiben"
        image="/assets/images/placeholder-gallery.jpg"
      />
      <Tile
        href="/culture"
        eyebrow="Kultur"
        title="Literatur &amp; Musik"
        image="/assets/images/placeholder-culture.jpg"
      />
    </div>
  </section>

  {/* CHAPTER 4 — live events from the platform backend */}
  <section class="bg-sand-100 py-28">
    <div class="max-w-screen-lg mx-auto px-6 md:px-10 grid md:grid-cols-[1fr_2fr] gap-16 items-start">
      <div>
        <div class="eyebrow mb-4">Bevorstehend</div>
        <h2 class="h-display">Auswahl aus unserem Kalender.</h2>
        <p class="mt-6 font-serif text-ink-500 leading-relaxed">
          Eine Übersicht der nächsten öffentlichen Anlässe — Lesungen,
          Konzerte, Spa-Rituale, saisonale Menüs. Automatisch aktualisiert.
        </p>
        <a
          href="/events"
          class="mt-8 inline-block font-sans text-xs tracking-widest uppercase text-ink-500 border-b border-sand-400 pb-1 hover:text-sand-600"
        >
          Alle Veranstaltungen
        </a>
      </div>
      <EventsWidget client:idle upcomingDays={90} limit={4} />
    </div>
  </section>

  {/* CHAPTER 5 — culinary feature, flipped chess-block */}
  <section class="bg-sand-50">
    <ChessBlock
      eyebrow="Unsere Küche"
      title="Der Spreewald auf dem Teller."
      body="Regionale Zutaten, leise interpretiert. Wir kochen mit dem, was der Wald, die Wiesen und die Fließe schenken — und lassen der Jahreszeit den Vortritt. Zwei Restaurants, eine Bar, ein Küchenchef der sich nicht beweisen muss."
      image="/assets/images/placeholder-kitchen.jpg"
      href="/restaurants"
      ctaLabel="Zur Kulinarik"
      imagePosition="right"
    />
  </section>
</BaseLayout>
