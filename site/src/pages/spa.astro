---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="Landtherme Spa · Bleiche Resort">
  <section class="pt-40 pb-32 bg-sand-50 min-h-screen">
    <div class="max-w-screen-lg mx-auto px-6 md:px-10">
      <div class="eyebrow mb-4">Ruhen</div>
      <h1 class="h-display mb-8">Landtherme Spa</h1>
      <p class="font-serif text-ink-500 leading-relaxed max-w-2xl">
        Platzhalter. Rituale, Anwendungen, Öffnungszeiten, Galerie.
      </p>
    </div>
  </section>
</BaseLayout>
