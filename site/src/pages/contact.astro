---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="Kontakt · Bleiche Resort">
  <section class="pt-40 pb-32 bg-sand-50 min-h-screen">
    <div class="max-w-screen-lg mx-auto px-6 md:px-10">
      <div class="eyebrow mb-4">Kontakt</div>
      <h1 class="h-display mb-8">Wir freuen uns auf Sie.</h1>
      <div class="font-serif text-ink-500 leading-relaxed space-y-2 max-w-xl">
        <p>Bleiche Resort &amp; Spa</p>
        <p>Burger Wohnsiedlung 70<br />03096 Burg (Spreewald)</p>
        <p class="pt-4">+49 (0) 35603 620</p>
        <p>
          <a href="mailto:info@bleiche-resort.de" class="underline decoration-sand-400 underline-offset-4 hover:text-sand-600">
            info@bleiche-resort.de
          </a>
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
